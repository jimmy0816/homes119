---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const gridPosts = posts.slice(1, 4);
---
<BaseLayout title="水管清洗費用、推薦、完整資訊" heroNav={true}>

  <!-- Hero（不動） -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">Taiwan Pipe Cleaning Guide</p>
      <h1>水管清洗<br><span>費用透明</span><br>中立資訊</h1>
      <p class="hero-desc">不賣服務、不收業者推薦費。幫你看懂行情、找對師傅，做出正確決定。</p>
      <div class="hero-actions">
        <a href="/price/" class="btn-primary">查費用行情</a>
        <a href="/blog/" class="btn-secondary">看文章</a>
      </div>
    </div>
  </section>

  <!-- Page Header -->
  <div class="page-header">
    <p>不賣服務，只給你做決定需要的資訊。費用行情、症狀判斷、師傅評比——全部公開透明。</p>
  </div>

  <!-- Filter Bar -->
  <div class="filter-bar">
    <button class="filter-btn active">全部</button>
    <button class="filter-btn">費用行情</button>
    <button class="filter-btn">症狀診斷</button>
    <button class="filter-btn">師傅評比</button>
    <button class="filter-btn">DIY 指南</button>
  </div>

  <!-- Featured Article -->
  {featured && (
    <div class="featured-section">
      <div class="feat-img-bg"></div>
      <div class="featured-body">
        <div class="tag">{featured.data.category || '費用行情'}</div>
        <h2>{featured.data.title}</h2>
        <p>{featured.data.description}</p>
        <a href={`/blog/${featured.id}/`} class="read-link">閱讀完整報告 →</a>
        <div class="feat-meta">
          {featured.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long' })}
          {featured.data.readingTime && ` · 閱讀時間 ${featured.data.readingTime} 分鐘`}
        </div>
      </div>
    </div>
  )}

  <!-- Articles Grid（3 欄） -->
  <div class="articles-grid-new">
    {gridPosts.map((post, i) => (
      <a href={`/blog/${post.id}/`} class={`article-card-new${i === gridPosts.length - 1 ? ' last' : ''}`}>
        <div class="ac-img"></div>
        <div class="article-body-new">
          <div class="tag">{post.data.category || '水管知識'}</div>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <div class="article-meta-new">
            <span>{post.data.category || '水管知識'}</span>
            <span>{post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long' })}</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Symptoms Grid（4 欄） -->
  <div class="symptom-section">
    <div class="symptom-inner">
      <h2 class="symptom-title">從症狀開始找答案</h2>
      <p class="symptom-sub">選擇你正在碰到的狀況，直接看對應的費用行情與解法</p>
      <div class="symptoms-grid-new">
        <div class="sym-card-new">
          <div class="sym-icon-wrap">
            <svg viewBox="0 0 18 18" fill="none" stroke="#E07020" stroke-width="1.5" stroke-linecap="round"><path d="M9 2v4M9 14v2M5 9H2M16 9h-3M6.5 6.5L4.5 4.5M13.5 13.5l-1.5-1.5M11.5 6.5l2-2M4.5 13.5l1.5-1.5"/><circle cx="9" cy="9" r="2.5"/></svg>
          </div>
          <h4>熱水變小、變弱</h4>
          <p>可能是水垢堆積或水管鏽蝕</p>
          <div class="sym-arrow">查看費用 →</div>
        </div>
        <div class="sym-card-new">
          <div class="sym-icon-wrap">
            <svg viewBox="0 0 18 18" fill="none" stroke="#E07020" stroke-width="1.5" stroke-linecap="round"><path d="M6 16c0-3 6-6 6-10a6 6 0 00-12 0c0 2 1.5 4 3 5"/><path d="M9 13v3"/></svg>
          </div>
          <h4>水有鐵鏽味</h4>
          <p>老舊鐵管氧化，水質含鐵量超標</p>
          <div class="sym-arrow">查看費用 →</div>
        </div>
        <div class="sym-card-new">
          <div class="sym-icon-wrap">
            <svg viewBox="0 0 18 18" fill="none" stroke="#E07020" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="6" width="14" height="8" rx="2"/><path d="M6 6V4a3 3 0 016 0v2"/></svg>
          </div>
          <h4>廚房浴室堵塞</h4>
          <p>管內油脂或異物堆積造成排水不順</p>
          <div class="sym-arrow">查看費用 →</div>
        </div>
        <div class="sym-card-new last">
          <div class="sym-icon-wrap">
            <svg viewBox="0 0 18 18" fill="none" stroke="#E07020" stroke-width="1.5" stroke-linecap="round"><path d="M3 14s1-1 4-1 5 2 8 2"/><path d="M9 4v6M7 8l2 2 2-2"/></svg>
          </div>
          <h4>天花板牆壁滲水</h4>
          <p>管路破損或接頭老化導致漏水</p>
          <div class="sym-arrow">查看費用 →</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Newsletter（黑底） -->
  <div class="newsletter-new">
    <div class="nl-left">
      <div class="nl-title">每月行情<br>報告</div>
      <p class="nl-sub">不推銷、不業配。只有真實的市場行情。</p>
    </div>
    <div class="nl-right">
      <div class="nl-input-wrap">
        <input class="nl-input" placeholder="your@email.com" type="email" />
        <button class="nl-btn">訂閱</button>
      </div>
      <span class="nl-note">每月最多一封，可隨時取消</span>
    </div>
  </div>

</BaseLayout>
