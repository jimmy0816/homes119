---
import '../styles/global.css';
interface Props { title: string; description?: string; }
const { title, description = 'homes119.com - 台灣最完整的水管清洗資訊站' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | homes119.com</title>
  <meta name="description" content={description} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="homes119.com" />
</head>
<body>
  <nav class="site-nav">
    <div class="container">
      <a href="/" class="nav-logo">homes119</a>
      <div class="nav-links">
        <a href="/price/">費用行情</a>
        <a href="/blog/">文章</a>
        <a href="/about/">關於我們</a>
      </div>
    </div>
  </nav>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="container">
      <p>© 2026 homes119.com — 台灣水管清洗資訊站 | <a href="/about/">關於我們</a></p>
      <p style="margin-top:0.5rem;font-size:0.8rem;">本站為資訊分享平台，不向讀者收費，亦不收取業者推薦費。</p>
    </div>
  </footer>
</body>
</html>
