---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  heroNav?: boolean;
}
const { title, description = 'homes119.com - 台灣最完整的水管清洗資訊站', heroNav = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | homes119.com</title>
  <meta name="description" content={description} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="homes119.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800;900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono&family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<body>
  <nav class={`site-nav${heroNav ? '' : ' solid'}`}>
    <div class="container">
      <a href="/" class="nav-logo">homes119</a>
      <div class="nav-links">
        <a href="/price/">費用行情</a>
        <a href="/blog/">文章</a>
        <a href="/about/">關於我們</a>
        <a href="/contact/" class="nav-cta">免費詢價</a>
      </div>
    </div>
  </nav>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo">homes119</a>
          <p>台灣水管清洗中立資訊站。<br>不賣服務、不收業者推薦費，<br>只給你做決定需要的資訊。</p>
        </div>
        <div>
          <p class="footer-col-title">導覽</p>
          <ul class="footer-col-links">
            <li><a href="/">首頁</a></li>
            <li><a href="/price/">費用行情</a></li>
            <li><a href="/blog/">文章</a></li>
            <li><a href="/about/">關於我們</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-col-title">服務</p>
          <ul class="footer-col-links">
            <li><a href="/contact/">免費詢價</a></li>
            <li><a href="/blog/">水管知識庫</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 HOMES119.COM — 台灣水管清洗資訊站</p>
        <p>本站為資訊分享平台，不向讀者收費，亦不收取業者推薦費。</p>
      </div>
    </div>
  </footer>
</body>
</html>
