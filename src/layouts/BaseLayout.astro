---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  heroNav?: boolean;
}
const { title, description = 'homes119.com - 台灣最完整的水管清洗資訊站', heroNav = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | homes119.com</title>
  <meta name="description" content={description} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="homes119.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400&family=Big+Shoulders+Display:wght@700;800;900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono&family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<body>
  <nav class={`site-nav${heroNav ? '' : ' solid'}`}>
    <div class="container">
      <a href="/" class="nav-logo">homes<em>119</em></a>
      <div class="nav-links">
        <a href="/price/">費用行情</a>
        <a href="#">症狀診斷</a>
        <a href="#">師傅評比</a>
        <a href="/blog/">知識庫</a>
      </div>
      <button class="nav-cta-btn">免費詢價</button>
    </div>
  </nav>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <div class="footer-logo">HOMES<em>119</em></div>
          <div class="footer-tagline">台灣最完整的水管清洗資訊站<br>費用透明 · 中立評比 · 不賣廣告</div>
        </div>
        <div class="footer-col">
          <h5 class="footer-col-title">資訊</h5>
          <a href="/price/">費用行情</a>
          <a href="#">症狀診斷</a>
          <a href="#">DIY 指南</a>
        </div>
        <div class="footer-col">
          <h5 class="footer-col-title">評比</h5>
          <a href="#">師傅評比</a>
          <a href="#">平台比較</a>
          <a href="/blog/">地區推薦</a>
        </div>
        <div class="footer-col">
          <h5 class="footer-col-title">關於</h5>
          <a href="/about/">我們的立場</a>
          <a href="#">合作師傅</a>
          <a href="/contact/">聯絡我們</a>
        </div>
      </div>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-bottom">
      <span>HOMES119 © 2026</span>
      <span class="footer-bottom-accent">中立資訊站 · 不收業者推薦費</span>
    </div>
  </footer>
</body>
</html>
